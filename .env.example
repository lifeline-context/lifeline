# Lifeline — modo NUVEM (M3 Tier 1). Copie para `.env` e preencha.
# O `.env` real está no .gitignore — NUNCA comite chave nem token.
# Detalhes: docs/M3_TIER1_SUPABASE.md

SUPABASE_URL=https://<seu-ref>.supabase.co
SUPABASE_KEY=<apikey do projeto: anon/publishable>   # vai no header `apikey`
SUPABASE_TOKEN=<access token de usuário (JWT)>        # `Authorization: Bearer` — escrita sob RLS

# Opcional — administração (aplicar schema via Management API/MCP). NÃO é usado pelo runtime.
# SUPABASE_ACCESS_TOKEN=sbp_xxx

# Opcional — MCP remoto (lifeline-mcp-remote)
# LIFELINE_STORE=supabase
# LIFELINE_OAUTH=1
# LIFELINE_MCP_PUBLIC_URL=https://seu-host
