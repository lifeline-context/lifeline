# Cache de runtime do Lifeline — NÃO é a fonte versionada.
# Reconstrua com: python -m lifeline migrate --from LIFELINE.md
.lifeline/
*.db
*.db-wal
*.db-shm

# segredos — NUNCA versionar (keys do Supabase etc.)
.env
*.env
# config MCP pessoal do dev (supabase etc.) — fora do repo
.mcp.local.json

# backups e snapshots/provas gerados
*.bak
CONTEXT_SNAPSHOT.md
FIRETEST_SNAPSHOT.md
EXAM_prompt.md
EXAM_key.md

__pycache__/
*.pyc

# caches de build/test + artefatos de empacotamento (PyPI)
*.egg-info/
.pytest_cache/
build/
dist/
.coverage
.coverage.*
htmlcov/

# rev0 arquivada — fica no disco e no HISTÓRICO do git, fora da árvore versionada (#0058)
_legacy/

# config local do Claude Code (helper de preview etc.) — fora do repo
.claude/
